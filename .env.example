KALSHI_API_KEY_ID=your_api_key_id
KALSHI_PRIVATE_KEY_PATH=/absolute/path/to/your/private-key.key
KALSHI_BASE_URL=https://demo-api.kalshi.co/trade-api/v2

# Production base URL:
# KALSHI_BASE_URL=https://api.elections.kalshi.com/trade-api/v2

# PostgreSQL / AWS database (required for analysis scripts)
PROD_ATHENA_HOST=your_db_host
PROD_ATHENA_PORT=5432
PROD_ATHENA_DB=postgres
PROD_ATHENA_USER=your_db_user
PROD_ATHENA_PASSWORD=your_db_password
